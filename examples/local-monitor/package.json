{
  "name": "local-monitor",
  "version": "1.0.0",
  "description": "Example TUI app to monitor local Keenetic/Netcraze devices status using @rci-tools",
  "private": true,
  "type": "module",
  "author": "Eralde",
  "license": "ISC",
  "scripts": {
    "clean": "rimraf dist",
    "dev": "tsx -r tsconfig-paths/register src/index.tsx",
    "fmt": "dprint fmt ./src/**/*.tsx",
    "build": "tsup src/index.tsx --format esm --dts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@pppp606/ink-chart": "^0.1.1",
    "@rci-tools/adapter-axios": "workspace:*",
    "@rci-tools/core": "workspace:*",
    "better-sqlite3": "^11.6.0",
    "ink": "^6.8.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.7",
    "rxjs": "^7.8.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "22.18.0",
    "@types/react": "^19.2.17",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "^5.6.3"
  }
}
